{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/fatwa/(.*)",
      "destination": "/fatwa.html?id=$1"
    },
    {
      "source": "/hadith/(.*)",
      "destination": "/details_hadith.html?id=$1"
    },
    {
      "source": "/scholar/(.*)",
      "destination": "/details_scholars.html?id=$1"
    },
    {
      "source": "/history/(.*)",
      "destination": "/history.html?id=$1"
    },
    {
      "source": "/jarh/(.*)",
      "destination": "/details_jarh.html?id=$1"
    }
  ]
}
